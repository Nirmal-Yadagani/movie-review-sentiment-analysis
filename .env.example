# ==========================================
# AWS & S3 CONFIGURATION (Data Storage)
# ==========================================
AWS_ACCESS_KEY_ID="your_aws_access_key_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key_here"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="your_imdb_bucket_name_here"

# ==========================================
# MLFLOW & DAGSHUB (Experiment Tracking & Registry)
# ==========================================
# Dagshub handles URI and auth natively in your scripts via dagshub.init(), 
# but these are required for GitHub Actions / CI environments where 
# interactive login isn't possible.
MLFLOW_TRACKING_URI="https://dagshub.com/Your_USERNAME/Your_repo_name.mlflow"
MLFLOW_TRACKING_USERNAME="Your_USERNAME"
MLFLOW_TRACKING_PASSWORD="your_dagshub_personal_access_token_here"

# ==========================================
# CI/CD PIPELINE CONFIGURATION
# ==========================================
# Used by your GitHub Actions to promote the correct model.
# This should match the name you log your model under in your evaluation script.
MODEL_NAME="MLPClassifier"

# ==========================================
# APPLICATION ROUTING & DOCKER CONFIG
# ==========================================
# Frontend Configuration
BACKEND_URL="http://model_backend:8080" # Used by Streamlit to hit FastAPI

# Backend Configuration
MODEL_PATH="/app/model" # Location of the MLflow PyFunc model inside the Docker container